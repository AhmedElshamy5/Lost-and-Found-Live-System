<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="640" prefWidth="940" stylesheets="@../css/app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.campuslostfound.client.controllers.BrowseItemsController">
    <top>
        <VBox spacing="8" styleClass="header-box">
            <padding>
                <Insets bottom="18" left="24" right="24" top="18" />
            </padding>
            <children>
                <Label styleClass="title-label" text="Browse Lost &amp; Found Reports" />
                <Label styleClass="subtitle-label" text="Reports are received from the TCP server." />
            </children>
        </VBox>
    </top>
    <center>
        <VBox spacing="14">
            <padding>
                <Insets bottom="22" left="22" right="22" top="22" />
            </padding>
            <children>
                <TableView fx:id="reportsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="55" text="ID" />
                        <TableColumn fx:id="typeColumn" prefWidth="75" text="Type" />
                        <TableColumn fx:id="nameColumn" prefWidth="150" text="Item" />
                        <TableColumn fx:id="categoryColumn" prefWidth="110" text="Category" />
                        <TableColumn fx:id="locationColumn" prefWidth="150" text="Location" />
                        <TableColumn fx:id="statusColumn" prefWidth="100" text="Status" />
                        <TableColumn fx:id="reporterColumn" prefWidth="180" text="Reporter" />
                        <TableColumn fx:id="dateColumn" prefWidth="130" text="Date" />
                    </columns>
                </TableView>
                <HBox alignment="CENTER" spacing="12">
                    <children>
                        <Button onAction="#handleRefresh" styleClass="primary-button" text="Refresh" />
                        <Button onAction="#handleDetails" text="Show Details" />
                        <Button onAction="#handleBack" text="Back" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
