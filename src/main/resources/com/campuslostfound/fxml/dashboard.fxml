<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="640" prefWidth="940" stylesheets="@../css/app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.campuslostfound.client.controllers.DashboardController">
    <top>
        <VBox spacing="8" styleClass="header-box">
            <padding>
                <Insets bottom="18" left="24" right="24" top="18" />
            </padding>
            <children>
                <Label styleClass="title-label" text="Student Dashboard" />
                <Label fx:id="welcomeLabel" styleClass="subtitle-label" text="Welcome" />
            </children>
        </VBox>
    </top>
    <center>
        <VBox alignment="TOP_CENTER" spacing="20">
            <padding>
                <Insets bottom="30" left="30" right="30" top="30" />
            </padding>
            <children>
                <GridPane hgap="12" maxWidth="560" styleClass="card" vgap="12">
                    <children>
                        <Label text="Server Host" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="hostField" text="localhost" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Port" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="portField" text="5555" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="Status" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <Label fx:id="connectionStatusLabel" styleClass="status-label" text="Offline" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    </children>
                </GridPane>
                <HBox alignment="CENTER" spacing="12">
                    <children>
                        <Button fx:id="connectButton" onAction="#handleConnect" styleClass="primary-button" text="Connect to Server" />
                        <Button fx:id="disconnectButton" onAction="#handleDisconnect" text="Disconnect" />
                        <Button onAction="#handleRefreshReports" text="Refresh Reports" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" spacing="16">
                    <children>
                        <Button onAction="#handleReportLostFound" prefWidth="180" styleClass="primary-button" text="Report Lost / Found" />
                        <Button onAction="#handleBrowse" prefWidth="180" text="Browse Reports" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
