<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="640" prefWidth="940" stylesheets="@../css/app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.campuslostfound.client.controllers.ReportItemController">
    <top>
        <VBox spacing="8" styleClass="header-box">
            <padding>
                <Insets bottom="18" left="24" right="24" top="18" />
            </padding>
            <children>
                <Label styleClass="title-label" text="Report Lost or Found Item" />
                <Label styleClass="subtitle-label" text="The report will be sent to the live server." />
            </children>
        </VBox>
    </top>
    <center>
        <VBox alignment="TOP_CENTER" spacing="18">
            <padding>
                <Insets bottom="28" left="28" right="28" top="28" />
            </padding>
            <children>
                <GridPane hgap="12" maxWidth="620" styleClass="card" vgap="12">
                    <children>
                        <Label text="Report Type" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <ComboBox fx:id="typeComboBox" promptText="Lost or Found" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Category" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <ComboBox fx:id="categoryComboBox" promptText="Choose category" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="Item Name" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="itemNameField" promptText="Example: Black wallet" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label text="Location" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <TextField fx:id="locationField" promptText="Example: Library entrance" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <Label text="Description" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <TextArea fx:id="descriptionArea" prefRowCount="5" promptText="Add useful details without private passwords or sensitive information." wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    </children>
                </GridPane>
                <Label fx:id="statusLabel" styleClass="status-label" text="Fill in all fields before submitting." />
                <HBox alignment="CENTER" spacing="12">
                    <children>
                        <Button onAction="#handleSubmit" styleClass="primary-button" text="Submit Report" />
                        <Button onAction="#handleClear" text="Clear" />
                        <Button onAction="#handleBack" text="Back" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
